# Copy to .env and adjust. .env is gitignored.

# ---- Postgres ----
POSTGRES_DB=basement
POSTGRES_USER=basement
POSTGRES_PASSWORD=basement_dev

# ---- MinIO ----
MINIO_ROOT_USER=basement
MINIO_ROOT_PASSWORD=basement_dev_secret

# ---- Backend ----
NODE_ENV=development
PORT=4000

# Composed from the values above; overridden inside the backend container by docker-compose.
DATABASE_URL=postgresql://basement:basement_dev@localhost:5432/basement?schema=public
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=basement
S3_SECRET_KEY=basement_dev_secret
S3_BUCKET_TILES=bargrid-tiles
S3_BUCKET_MEDIA=inventory-media
S3_BUCKET_AUDIT=audit-archive

# Sprint 2 sync auth — replace before exposing the API beyond localhost.
SYNC_TOKEN=dev-sync-token-change-me

# Sprint 3 JWT auth — must be ≥16 chars; rotate to invalidate all sessions.
JWT_SECRET=dev-jwt-secret-change-me-at-least-16-chars
JWT_EXPIRES_IN=12h

# Sprint 6 hardening
RATE_LIMIT_PER_MIN=600
