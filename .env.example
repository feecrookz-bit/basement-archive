# ---- Postgres ----
DATABASE_URL=postgresql://tracker:tracker@db:5432/tracker

# ---- Discovery (DEX Screener) ----
DISCOVERY_MODE=poll          # poll | ws
DISCOVERY_POLL_SECONDS=6
DISCOVERY_CHAINS=solana      # comma sep; empty = all chains

# ---- Wallets (Helius / Solana) ----
WALLET_MODE=webhook          # webhook (FREE tier) | ws (paid plan) | off
HELIUS_API_KEY=
HELIUS_WS_URL=wss://atlas-mainnet.helius-rpc.com
# webhook mode: public base URL Helius POSTs to. Leave empty in GitHub
# Codespaces (auto-derived; set port 8000 visibility to Public). The app
# creates/updates the Helius webhook automatically via their API.
WEBHOOK_PUBLIC_URL=

# ---- Signal scoring ----
FRESH_HOURS=24

# ---- Optional alerts ----
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Safety gates (v2) ----
MIN_LIQUIDITY_USD=15000
MIN_VOLUME_H1_USD=5000
MAX_FDV_USD=5000000
MAX_TOP10_PCT=35
REQUIRE_MINT_REVOKED=true
MIN_BUY_SOL=0.5
MIN_SIGNAL_SCORE=1.5

# ---- Paper ledger (v2) ----
PAPER_ENABLED=true
PAPER_STAKE_SOL=1.0
PAPER_TP_PCT=80
PAPER_SL_PCT=40
PAPER_TIMEOUT_HOURS=12
PAPER_CHECK_SECONDS=60
ASSUMED_SLIPPAGE_PCT=6
HELIUS_RPC_URL=https://mainnet.helius-rpc.com

# ---- Moonshot mode (low-MC 100x hunting) ----
MOONSHOT_ENABLED=true
MOONSHOT_MIN_FDV=50000
MOONSHOT_MAX_FDV=1500000
MOONSHOT_MIN_LIQ_PCT_FDV=8
MOONSHOT_MIN_LIQ_USD=10000
MOONSHOT_MAX_TOP10_PCT=30
MOONSHOT_FRESH_HOURS=168
MOONSHOT_MIN_BUY_SOL=0.25
MOONSHOT_MIN_BUY_EVENTS=3
MOONSHOT_ACCUM_WINDOW_HOURS=168
MOONSHOT_MIN_ACCUM_SPAN_HOURS=12
MOONSHOT_SL_PCT=60
MOONSHOT_TIMEOUT_HOURS=720

# ---- Method-3 gates (v2.2, momentum only) ----
M3_MIN_BUY_SELL_RATIO_H1=1.0
M3_MIN_VOLUME_M5_USD=1000
M3_REQUIRE_HOLDER_GROWTH=false
HOLDER_COUNT_MAX_PAGES=5

# ---- Binance events (v2.2) ----
BINANCE_ENABLED=true
BINANCE_POLL_SECONDS=300

# ---- Rotation overlay (v2.3, Method 6) ----
ROTATION_ENABLED=true
ROTATION_POLL_SECONDS=3600
ROTATION_SHIFT_PP=0.5

# ---- Pump.fun graduation watcher (v2.2) ----
PUMPFUN_ENABLED=true
PUMPPORTAL_WS_URL=wss://pumpportal.fun/api/data
GRAD_RECLAIM_WINDOW_HOURS=24
GRAD_MIN_DUMP_PCT=20
GRAD_MONITOR_MAX=60
