# Copy to .env. Paper mode needs NO exchange keys (public market data only).
DATABASE_URL=postgresql://sentinel:sentinel@postgres:5432/sentinel
REDIS_URL=redis://redis:6379/0

# Required ONLY for live trading — which additionally requires config live:true,
# the CLI confirmation flag, and >=30 logged paper-trading days. Leave empty.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ---- Dashboard sign-in (v3.1) ----
# Unset = auth OFF (fine for localhost / SSH port-forward). Set a password to
# expose the dashboard beyond localhost; set SESSION_SECRET so sessions
# survive restarts.
DASHBOARD_PASSWORD=
SESSION_SECRET=

# ---- Notifications (v3.1) — silent no-op when unset ----
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
